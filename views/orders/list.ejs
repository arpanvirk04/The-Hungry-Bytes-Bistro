<!DOCTYPE html>
<html>
<head>
  <title>Order Management</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <h1>Order Management</h1>
  <div class="navigation-buttons">
    <a href="/"><button>Restaurant Home</button></a>
    <a href="/drivers/register"><button>Register as Driver</button></a>
    <a href="/drivers/login"><button>Driver Login</button></a>
    <a href="/drivers/deliveries"><button>Driver Deliveries</button></a>
  </div>

  <% if (orders.length > 0) { %>
    <table>
      <thead>
        <tr>
          <th>Order ID</th>
          <th>Customer Name</th>
          <th>Delivery Address</th>
          <th>Items</th>
          <th>Status</th>
          <th>Driver</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% orders.forEach(order => { %>
          <tr>
            <td><%= order._id %></td>
            <td><%= order.customerName %></td>
            <td><%= order.deliveryAddress %></td>
            <td><%= order.items.join(", ") %></td>
            <td><%= order.status %></td>
            <td><%= order.driver ? `${order.driver.fullName} (${order.driver.vehicle.licensePlate})` : "Unassigned" %></td>
            <td>
              <form action="/orders/<%= order._id %>/update" method="POST" class="inline-form">
                <select name="status" required>
                  <option value="RECEIVED" <%= order.status === "RECEIVED" ? "selected" : "" %>>RECEIVED</option>
                  <option value="READY FOR DELIVERY" <%= order.status === "READY FOR DELIVERY" ? "selected" : "" %>>READY FOR DELIVERY</option>
                  <option value="IN TRANSIT" <%= order.status === "IN TRANSIT" ? "selected" : "" %>>IN TRANSIT</option>
                  <option value="DELIVERED" <%= order.status === "DELIVERED" ? "selected" : "" %>>DELIVERED</option>
                </select>
                <button type="submit">Update</button>
              </form>
              <form action="/orders/<%= order._id %>/assign" method="POST" class="inline-form">
                <select name="driverId" required>
                  <% drivers.forEach(driver => { %>
                    <option value="<%= driver._id %>" <%= order.driver && order.driver._id.equals(driver._id) ? "selected" : "" %>>
                      <%= driver.fullName %> (<%= driver.vehicle.licensePlate %>)
                    </option>
                  <% }) %>
                </select>
                <button type="submit">Assign</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } else { %>
    <p>No orders found.</p>
  <% } %>
</body>
</html>
