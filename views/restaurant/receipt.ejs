<!DOCTYPE html>
<html>
<head>
  <title>The Hungry Bytes Bistro</title>
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <header>
    <img src="/images/logo.png" alt="Hungry Byte Bistro Logo" class="logo">
    <h1>Order Receipt</h1>
  </header>
  <main>
    <section class="receipt">
      <h2>Thank you for your order, <%= order.customerName %>!</h2>
      <p><strong>Order Confirmation Number:</strong> <%= order._id %></p>
      <p><strong>Delivery Address:</strong> <%= order.deliveryAddress %></p>
      <p><strong>Items Ordered:</strong> <%= order.items.join(", ") %></p>
      <p><strong>Status:</strong> <%= order.status %></p>
    </section>
    <a href="/"><button>Return to Home</button></a>
  <br> <br> <br> <br> <br>
  <!-- Footer Section -->
<footer class="footer">
  <div class="footer-content">
    <div class="footer-logo">
      <h1>The Hungry Bytes Bistro <span>Group 7</span></h1>
    </div>
    <div class="social-links">
      <a href="https://twitter.com/" target="_blank" class="twitter">Twitter</a>
      <a href="https://www.facebook.com/" target="_blank" class="facebook">Facebook</a>
      <a href="https://www.instagram.com/" target="_blank" class="instagram">Instagram</a>
    </div>
  </div>

  <div class="contact-info">
    <div>
      <h5>Get In Touch</h5>
      <p>205 Humber College Blvd</p>
      <p>Etobicoke ON M9W 5L7</p>
    </div>
    <div>
      <h5>Opening Hours</h5>
      <p>Mon – Fri: 9AM – 5PM</p>
      <p>+(416) 675-3111</p>
    </div>
  </div>

  <div class="footer-bottom">
    <p>&copy; <a href="#">Group 7 - HTML Course</a>. All Rights Reserved. Designed by <a href="https://htmlcodex.com" target="_blank">HTML Codex</a></p>
  </div>
</footer>

  <!-- Footer End -->
  </main>
</body>
</html>

